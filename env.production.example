# ─────────────────────────────────────────────────────────────
# Variables de PRODUCCION de trainingloja.
# En el VPS: copia este archivo a ".env" y pon valores REALES y fuertes.
#   cp env.production.example .env
# El ".env" NUNCA se sube a git (ya esta en .gitignore).
# ─────────────────────────────────────────────────────────────

# Base de datos (Postgres)
POSTGRES_USER=trainingloja
POSTGRES_PASSWORD=cambia_esto_por_una_clave_larga_y_aleatoria
POSTGRES_DB=trainingloja

# La URL usa el MISMO usuario/clave/db de arriba, y host "db"
# (el nombre del servicio en docker-compose). Manten la clave sincronizada.
DATABASE_URL=postgresql://trainingloja:cambia_esto_por_una_clave_larga_y_aleatoria@db:5432/trainingloja?schema=public

# Autenticacion (JWT). OBLIGATORIO y FUERTE: en produccion la API no arranca
# si esto queda con el placeholder o con menos de 32 caracteres.
# Genera uno real con:   openssl rand -base64 48
JWT_SECRET=cambia_esto_por_un_secreto_muy_largo_y_aleatorio
JWT_EXPIRES=7d

# CORS: dominios del frontend permitidos, separados por coma (sin espacios).
# Ejemplo:  CORS_ORIGINS=https://trainingloja.vercel.app
# Si lo dejas vacio, se permite cualquier origen (NO recomendado en produccion).
CORS_ORIGINS=
